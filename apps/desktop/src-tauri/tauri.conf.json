{
  "package": {
    "productName": "GingaFlow",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "http": {
        "all": true,
        "request": true,
        "scope": ["https://**"]
      },
      "shell": {
        "all": false,
        "open": true
      },
      "path": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "",
      "externalBin": [],
      "icon": [],
      "identifier": "com.gingaflow.app",
      "longDescription": "",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": []
      },
      "resources": [],
      "shortDescription": "",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256"
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 768,
        "resizable": true,
        "title": "GingaFlow",
        "width": 1024
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "pnpm --filter @gingaflow/desktop build",
    "beforeDevCommand": "pnpm --filter @gingaflow/desktop dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  }
}

