generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                  String               @id @default(uuid())
  name                String
  document            String?              @unique
  plan                String               @default("FREE")
  active              Boolean              @default(true)
  created_at          DateTime             @default(now())
  updated_at          DateTime             @updatedAt
  activityTypes       ActivityType[]
  settings            AppSettings?
  attendances         Attendance[]
  graduations         Graduation[]
  graduationLevels    GraduationLevel[]
  receivables         Receivable[]
  receivablePayments  ReceivablePayment[]
  receivableHistories ReceivableHistory[]
  students            Student[]
  studentActivities   StudentActivity[]
  studentTurmas       StudentTurma[]
  teachers            Teacher[]
  teacherTurmas       TeacherTurma[]
  turmas              Turma[]
  turmaSchedules      TurmaSchedule[]
  classSessions       ClassSession[]
  units               Unit[]
  users               User[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  email          String       @unique
  password_hash  String
  role           String
  active         Boolean      @default(true)
  relatedId      String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  teacher        Teacher?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Student {
  id                  String            @id @default(uuid())
  organizationId      String
  full_name           String
  nickname            String?
  cpf                 String
  birth_date          String?
  email               String?
  phone               String?
  enrollment_date     String
  status              String
  notes               String?
  currentGraduationId String?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  attendances         Attendance[]
  graduations         Graduation[]
  receivables         Receivable[]
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities          StudentActivity[]
  studentTurmas       StudentTurma[]
  schedules           TurmaSchedule[]   @relation("StudentSchedules")
  currentGraduation   GraduationLevel?  @relation("StudentCurrentGraduation", fields: [currentGraduationId], references: [id])

  @@unique([organizationId, cpf])
}

model Teacher {
  id                  String          @id @default(uuid())
  organizationId      String
  full_name           String
  nickname            String?
  cpf                 String
  birth_date          String?
  email               String?
  phone               String?
  graduation          String?
  status              String
  notes               String?
  userId              String?         @unique
  created_at          DateTime        @default(now())
  updated_at          DateTime        @updatedAt
  promotedGraduations Graduation[]    @relation("PromoterTeacher")
  organization        Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                User?           @relation(fields: [userId], references: [id])
  teacherTurmas       TeacherTurma[]  @relation("TeacherTurmaRel")
  turmas              Turma[]         @relation("TurmaTeacher")
  schedules           TurmaSchedule[] @relation("ScheduleTeacher")

  @@unique([organizationId, cpf])
}

model Unit {
  id                     String       @id @default(uuid())
  organizationId         String
  name                   String
  address                String?
  color                  String?
  defaultMonthlyFeeCents Int?
  defaultPaymentMethod   String?
  status                 String
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt
  turmas                 Turma[]
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Turma {
  id                     String          @id @default(uuid())
  organizationId         String
  name                   String
  unitId                 String
  activityTypeId         String?
  teacherId              String?
  schedule               String? // Manter temporariamente para migração, depois pode ser removido ou marcado como opcional
  capacity               Int?            @default(0)
  durationMinutes        Int?            @default(60)
  defaultMonthlyFeeCents Int?
  defaultPaymentMethod   String?
  status                 String
  created_at             DateTime        @default(now())
  updated_at             DateTime        @updatedAt
  attendances            Attendance[]
  studentLinks           StudentTurma[]
  teacherLinks           TeacherTurma[]
  schedules              TurmaSchedule[]
  classSessions          ClassSession[]
  activityType           ActivityType?   @relation(fields: [activityTypeId], references: [id])
  organization           Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher                Teacher?        @relation("TurmaTeacher", fields: [teacherId], references: [id])
  unit                   Unit            @relation(fields: [unitId], references: [id], onDelete: Cascade)
  receivables            Receivable[]
}

model TurmaSchedule {
  id             String         @id @default(uuid())
  organizationId String
  turmaId        String
  dayOfWeek      String // SEG, TER, QUA, QUI, SEX, SAB, DOM
  startTime      String // HH:mm
  teacherId      String?
  created_at     DateTime       @default(now())
  updated_at     DateTime       @updatedAt
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  turma          Turma          @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  teacher        Teacher?       @relation("ScheduleTeacher", fields: [teacherId], references: [id])
  classSessions  ClassSession[]
  students       Student[]      @relation("StudentSchedules")

  @@unique([turmaId, dayOfWeek, startTime])
}

model ClassSession {
  id              String         @id @default(uuid())
  organizationId  String
  turmaId         String
  turmaScheduleId String?
  date            String // ISO 2024-03-04
  status          String // SCHEDULED, COMPLETED, CANCELLED
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  turma           Turma          @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  schedule        TurmaSchedule? @relation(fields: [turmaScheduleId], references: [id])
  attendances     Attendance[]
}

model Receivable {
  id              String   @id @default(uuid())
  organizationId  String
  studentId       String
  turmaId         String?

  description     String?
  period          String

  originalValue   Int
  discount        Int      @default(0)
  interest        Int      @default(0)
  fine            Int      @default(0)

  finalValue      Int
  paidValue       Int      @default(0)
  balance         Int

  dueDate         String
  promiseDate     String?

  status          String // PAID, PARTIAL, OPEN, OVERDUE, NEGOTIATED, CANCELLED

  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student         Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  turma           Turma?              @relation(fields: [turmaId], references: [id], onDelete: SetNull)
  payments        ReceivablePayment[] @relation("ReceivablePayments")
  history         ReceivableHistory[] @relation("ReceivableHistories")

  @@unique([studentId, period])
}

model ReceivablePayment {
  id             String   @id @default(uuid())
  organizationId String
  receivableId   String
  amount         Int
  method         String // PIX, DINHEIRO, CARTAO, TRANSFERENCIA
  paidAt         String
  createdBy      String?
  notes          String?

  created_at     DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  receivable     Receivable   @relation("ReceivablePayments", fields: [receivableId], references: [id], onDelete: Cascade)
}

model ReceivableHistory {
  id             String   @id @default(uuid())
  organizationId String
  receivableId   String
  action         String
  oldValue       String?
  newValue       String?
  createdBy      String?

  created_at     DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  receivable     Receivable   @relation("ReceivableHistories", fields: [receivableId], references: [id], onDelete: Cascade)
}

model Graduation {
  id                   String       @id @default(uuid())
  organizationId       String
  studentId            String
  previousGraduationId String?
  newGraduationId      String
  date                 String
  teacherId            String?
  type                 String
  notes                String?
  created_at           DateTime     @default(now())
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student              Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher              Teacher?     @relation("PromoterTeacher", fields: [teacherId], references: [id])
}

model Attendance {
  id             String        @id @default(uuid())
  organizationId String
  studentId      String
  turmaId        String? // Optional for legacy
  sessionId      String? // New session relationship
  date           String? // Legacy
  status         String // PRESENT, ABSENT, JUSTIFIED
  notes          String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  time           String? // Legacy
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  turma          Turma?        @relation(fields: [turmaId], references: [id], onDelete: Cascade)
  session        ClassSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([studentId, sessionId])
}

model AppSettings {
  id                   String       @id @default(uuid())
  organizationId       String       @unique
  groupName            String       @default("Grupo de Capoeira")
  logoUrl              String?
  themeColor           String       @default("blue")
  defaultMonthlyFee    Int          @default(0)
  defaultPaymentMethod String       @default("PIX")
  updated_at           DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model GraduationLevel {
  id              String       @id @default(uuid())
  organizationId  String
  name            String
  description     String?
  category        String?
  grau            Int?
  cordaType       String?
  color           String?
  colorLeft       String?
  colorRight      String?
  pontaLeft       String?
  pontaRight      String?
  order           Int
  active          Boolean      @default(true)
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currentStudents Student[]    @relation("StudentCurrentGraduation")
}

model ActivityType {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  usaGraduacao   Boolean           @default(true)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  students       StudentActivity[]
  turmas         Turma[]

  @@unique([organizationId, name])
}

model TeacherTurma {
  id             String       @id @default(uuid())
  organizationId String
  teacherId      String
  turmaId        String
  created_at     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher        Teacher      @relation("TeacherTurmaRel", fields: [teacherId], references: [id], onDelete: Cascade)
  turma          Turma        @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([teacherId, turmaId])
}

model StudentTurma {
  id                    String       @id @default(uuid())
  organizationId        String
  studentId             String
  turmaId               String
  status                String       @default("ACTIVE") // ACTIVE, INACTIVE, DROPPED
  startDate             String? // Enrollment start
  endDate               String? // Enrollment end
  customMonthlyFeeCents Int? // Override for this enrollment
  created_at            DateTime     @default(now())
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student               Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  turma                 Turma        @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([studentId, turmaId])
}

model StudentActivity {
  organizationId String
  studentId      String
  activityTypeId String
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, activityTypeId])
}
