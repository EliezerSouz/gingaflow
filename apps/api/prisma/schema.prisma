generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Student {
  id             String        @id @default(uuid())
  full_name      String
  nickname       String?       // Nome artístico / Apelido
  cpf            String        @unique
  birth_date     String?
  email          String?
  phone          String?
  enrollment_date String
  status         String
  notes          String?
  currentGraduationId String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  payments       Payment[]
  graduations    Graduation[]
  studentTurmas  StudentTurma[]
  attendances    Attendance[]
  activities     StudentActivity[]
}

model Teacher {
  id             String        @id @default(uuid())
  full_name      String
  nickname       String?       // Nome artístico / Apelido
  cpf            String        @unique
  birth_date     String?
  email          String?
  phone          String?
  graduation     String?
  status         String
  notes          String?
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt
  
  userId         String?       @unique
  user           User?         @relation(fields: [userId], references: [id])
  
  turmas         Turma[]       @relation("TurmaTeacher")
  teacherTurmas  TeacherTurma[] @relation("TeacherTurmaRel")
  promotedGraduations Graduation[] @relation("PromoterTeacher")
}

model Payment {
  id              String    @id @default(uuid())
  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  monthlyFeeCents Int
  dueDay          Int
  period          String
  status          String
  paidAt          DateTime?
  method          String?
  notes           String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  @@unique([studentId, period])
}

model Graduation {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  previousGraduationId String?
  newGraduationId String
  date        String
  teacherId   String?
  teacher     Teacher? @relation("PromoterTeacher", fields: [teacherId], references: [id])
  type        String
  notes       String?
  created_at  DateTime @default(now())
}

model Unit {
  id         String   @id @default(uuid())
  name       String
  address    String?
  color      String?
  defaultMonthlyFeeCents Int?
  defaultPaymentMethod   String?
  status     String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  turmas     Turma[]
}

model Turma {
  id           String         @id @default(uuid())
  name         String
  unitId       String
  unit         Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
  activityTypeId String?
  activityType   ActivityType?  @relation(fields: [activityTypeId], references: [id])
  teacherId    String?
  teacher      Teacher?       @relation("TurmaTeacher", fields: [teacherId], references: [id])
  schedule     String?
  defaultMonthlyFeeCents Int?
  defaultPaymentMethod   String?
  status       String
  created_at   DateTime       @default(now())
  updated_at   DateTime       @updatedAt
  teacherLinks TeacherTurma[]
  studentLinks StudentTurma[]
  attendances  Attendance[]
}

model TeacherTurma {
  id         String   @id @default(uuid())
  teacherId  String
  turmaId    String
  created_at DateTime @default(now())
  teacher    Teacher  @relation("TeacherTurmaRel", fields: [teacherId], references: [id], onDelete: Cascade)
  turma      Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([teacherId, turmaId])
}

model StudentTurma {
  id         String   @id @default(uuid())
  studentId  String
  turmaId    String
  created_at DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  turma      Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([studentId, turmaId])
}

model Attendance {
  id         String   @id @default(uuid())
  studentId  String
  turmaId    String
  date       String
  status     String   // PRESENT, ABSENT
  notes      String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  turma      Turma    @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([studentId, turmaId, date])
}

model User {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  password_hash String
  role          String   // ADMIN, PROFESSOR
  active        Boolean  @default(true)
  relatedId     String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
  teacher       Teacher?
}

model AppSettings {
  id                   String   @id @default(uuid()) // Usually only one record
  groupName            String   @default("Grupo de Capoeira")
  logoUrl              String?
  themeColor           String   @default("blue")
  defaultMonthlyFee    Int      @default(0)
  defaultPaymentMethod String   @default("PIX")
  updated_at           DateTime @updatedAt
}

model GraduationLevel {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String?
  grau        Int?
  cordaType   String?  // UNICA, DUPLA, COM_PONTAS
  color       String?
  colorLeft   String?
  colorRight  String?
  pontaLeft   String?
  pontaRight  String?
  order       Int
  active      Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model ActivityType {
  id           String    @id @default(uuid())
  name         String    @unique
  usaGraduacao Boolean   @default(true)
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  students     StudentActivity[]
  turmas       Turma[]
}

model StudentActivity {
  studentId      String
  activityTypeId String
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)

  @@id([studentId, activityTypeId])
}
