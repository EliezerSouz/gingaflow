generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                String            @id @default(uuid())
  name              String
  document          String?           @unique
  plan              String            @default("FREE")
  active            Boolean           @default(true)
  created_at        DateTime          @default(now())
  updated_at        DateTime          @updatedAt
  activityTypes     ActivityType[]
  settings          AppSettings?
  attendances       Attendance[]
  graduations       Graduation[]
  graduationLevels  GraduationLevel[]
  payments          Payment[]
  students          Student[]
  studentActivities StudentActivity[]
  studentTurmas     StudentTurma[]
  teachers          Teacher[]
  teacherTurmas     TeacherTurma[]
  turmas            Turma[]
  units             Unit[]
  users             User[]
}

model User {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  email          String       @unique
  password_hash  String
  role           String
  active         Boolean      @default(true)
  relatedId      String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  teacher        Teacher?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Student {
  id                  String            @id @default(uuid())
  organizationId      String
  full_name           String
  nickname            String?
  cpf                 String
  birth_date          String?
  email               String?
  phone               String?
  enrollment_date     String
  status              String
  notes               String?
  currentGraduationId String?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt
  attendances         Attendance[]
  graduations         Graduation[]
  payments            Payment[]
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  activities          StudentActivity[]
  studentTurmas       StudentTurma[]

  @@unique([organizationId, cpf])
}

model Teacher {
  id                  String         @id @default(uuid())
  organizationId      String
  full_name           String
  nickname            String?
  cpf                 String
  birth_date          String?
  email               String?
  phone               String?
  graduation          String?
  status              String
  notes               String?
  userId              String?        @unique
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt
  promotedGraduations Graduation[]   @relation("PromoterTeacher")
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                User?          @relation(fields: [userId], references: [id])
  teacherTurmas       TeacherTurma[] @relation("TeacherTurmaRel")
  turmas              Turma[]        @relation("TurmaTeacher")

  @@unique([organizationId, cpf])
}

model Unit {
  id                     String       @id @default(uuid())
  organizationId         String
  name                   String
  address                String?
  color                  String?
  defaultMonthlyFeeCents Int?
  defaultPaymentMethod   String?
  status                 String
  created_at             DateTime     @default(now())
  updated_at             DateTime     @updatedAt
  turmas                 Turma[]
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Turma {
  id                     String         @id @default(uuid())
  organizationId         String
  name                   String
  unitId                 String
  activityTypeId         String?
  teacherId              String?
  schedule               String?
  defaultMonthlyFeeCents Int?
  defaultPaymentMethod   String?
  status                 String
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  attendances            Attendance[]
  studentLinks           StudentTurma[]
  teacherLinks           TeacherTurma[]
  activityType           ActivityType?  @relation(fields: [activityTypeId], references: [id])
  organization           Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher                Teacher?       @relation("TurmaTeacher", fields: [teacherId], references: [id])
  unit                   Unit           @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model Payment {
  id              String       @id @default(uuid())
  organizationId  String
  studentId       String
  monthlyFeeCents Int
  dueDay          Int
  period          String
  status          String
  paidAt          DateTime?
  method          String?
  notes           String?
  created_at      DateTime     @default(now())
  updated_at      DateTime     @updatedAt
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student         Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, period])
}

model Graduation {
  id                   String       @id @default(uuid())
  organizationId       String
  studentId            String
  previousGraduationId String?
  newGraduationId      String
  date                 String
  teacherId            String?
  type                 String
  notes                String?
  created_at           DateTime     @default(now())
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student              Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  teacher              Teacher?     @relation("PromoterTeacher", fields: [teacherId], references: [id])
}

model Attendance {
  id             String       @id @default(uuid())
  organizationId String
  studentId      String
  turmaId        String
  date           String
  status         String
  notes          String?
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  time           String?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  turma          Turma        @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([studentId, turmaId, date, time])
}

model AppSettings {
  id                   String       @id @default(uuid())
  organizationId       String       @unique
  groupName            String       @default("Grupo de Capoeira")
  logoUrl              String?
  themeColor           String       @default("blue")
  defaultMonthlyFee    Int          @default(0)
  defaultPaymentMethod String       @default("PIX")
  updated_at           DateTime     @updatedAt
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model GraduationLevel {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  description    String?
  category       String?
  grau           Int?
  cordaType      String?
  color          String?
  colorLeft      String?
  colorRight     String?
  pontaLeft      String?
  pontaRight     String?
  order          Int
  active         Boolean      @default(true)
  created_at     DateTime     @default(now())
  updated_at     DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ActivityType {
  id             String            @id @default(uuid())
  organizationId String
  name           String
  usaGraduacao   Boolean           @default(true)
  created_at     DateTime          @default(now())
  updated_at     DateTime          @updatedAt
  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  students       StudentActivity[]
  turmas         Turma[]

  @@unique([organizationId, name])
}

model TeacherTurma {
  id             String       @id @default(uuid())
  organizationId String
  teacherId      String
  turmaId        String
  created_at     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  teacher        Teacher      @relation("TeacherTurmaRel", fields: [teacherId], references: [id], onDelete: Cascade)
  turma          Turma        @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([teacherId, turmaId])
}

model StudentTurma {
  id             String       @id @default(uuid())
  organizationId String
  studentId      String
  turmaId        String
  created_at     DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  turma          Turma        @relation(fields: [turmaId], references: [id], onDelete: Cascade)

  @@unique([studentId, turmaId])
}

model StudentActivity {
  organizationId String
  studentId      String
  activityTypeId String
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  student        Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@id([studentId, activityTypeId])
}
