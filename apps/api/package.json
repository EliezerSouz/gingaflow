{
  "name": "@gingaflow/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "prisma": "prisma",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "echo"
  },
  "dependencies": {
    "@fastify/cors": "^8.4.0",
    "@fastify/jwt": "^6.3.0",
    "@gingaflow/shared": "workspace:*",
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.25.0",
    "pino": "^8.17.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "prisma": "^5.14.0",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
